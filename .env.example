# Pokemon Draft - Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local or any file containing real API keys to version control!

# ============================================================================
# SUPABASE CONFIGURATION (REQUIRED)
# ============================================================================

# Your Supabase project URL
# Get this from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co

# Supabase anonymous/public API key (safe to expose in client-side code)
# This key has limited permissions defined by your RLS policies
# Get this from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ⚠️ SECURITY WARNING ⚠️
# DO NOT use SUPABASE_SERVICE_ROLE_KEY in production client-side code!
# Service role keys bypass RLS and should ONLY be used in secure server environments
# If you need admin operations, create secure API routes that use the service key server-side

# ============================================================================
# AUTHENTICATION (OPTIONAL)
# ============================================================================

# NextAuth secret (if using NextAuth)
# Generate a random string: openssl rand -base64 32
# NEXTAUTH_SECRET=your-nextauth-secret-here

# NextAuth URL (your application URL)
# NEXTAUTH_URL=http://localhost:3000

# ============================================================================
# SENTRY ERROR TRACKING (OPTIONAL)
# ============================================================================

# Sentry DSN for error tracking (REQUIRED for production)
# Get this from: https://sentry.io/settings/projects/your-project/keys/
# NEXT_PUBLIC_SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-project-id
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=pokemon-draft

# ============================================================================
# DEVELOPMENT/PRODUCTION FLAGS
# ============================================================================

# Node environment (development, production, test)
NODE_ENV=development

# Enable debug logging (true/false)
DEBUG=false

# ============================================================================
# SITE URL (REQUIRED for production)
# ============================================================================

# Your deployed site URL (used for OG images, sitemap, robots.txt)
# NEXT_PUBLIC_SITE_URL=https://pokemondraftleague.com

# ============================================================================
# ANALYTICS — PostHog (OPTIONAL)
# ============================================================================

# PostHog project API key
# Get this from: https://us.posthog.com/settings/project
# NEXT_PUBLIC_POSTHOG_KEY=phc_your-key-here
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ============================================================================
# RATE LIMITING — Upstash Redis (RECOMMENDED for production)
# ============================================================================

# Upstash Redis REST credentials (free tier: 10K requests/day)
# Get this from: https://console.upstash.com
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token-here

# ============================================================================
# PUSH NOTIFICATIONS (OPTIONAL)
# ============================================================================

# VAPID keys for Web Push notifications
# Generate with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
# VAPID_PRIVATE_KEY=your-vapid-private-key

# ============================================================================
# SECURITY NOTES
# ============================================================================

# 1. NEVER commit .env.local or .env.production to version control
# 2. Use different keys for development, staging, and production
# 3. Rotate API keys regularly (every 90 days recommended)
# 4. Use Supabase's RLS policies to restrict what the anon key can access
# 5. Monitor API usage for unusual patterns
# 6. Set up alerts for failed authentication attempts
# 7. Use environment-specific Supabase projects (dev, staging, prod)

# ============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================================
#
# DATABASE:
# [ ] Run migrations/DEPLOY_TO_PRODUCTION.sql in Supabase SQL Editor
# [ ] Run migrations/fix-rls-policies.sql in Supabase SQL Editor
# [ ] Verify: SELECT * FROM _migrations ORDER BY applied_at;
#
# SUPABASE DASHBOARD:
# [ ] Authentication > Providers > Enable Google OAuth (client ID + secret)
# [ ] Authentication > Providers > Enable Discord OAuth (client ID + secret)
# [ ] Authentication > Email Templates > Configure custom SMTP (Resend/Postmark)
# [ ] Authentication > URL Configuration > Set Site URL to your domain
# [ ] Authentication > URL Configuration > Add redirect URL: https://yourdomain.com/auth/callback
#
# VERCEL ENVIRONMENT VARIABLES:
# [ ] NEXT_PUBLIC_SUPABASE_URL
# [ ] NEXT_PUBLIC_SUPABASE_ANON_KEY
# [ ] NEXT_PUBLIC_SITE_URL (your production domain)
# [ ] NEXT_PUBLIC_SENTRY_DSN
# [ ] SENTRY_ORG + SENTRY_PROJECT + SENTRY_AUTH_TOKEN
# [ ] NEXT_PUBLIC_POSTHOG_KEY + NEXT_PUBLIC_POSTHOG_HOST
# [ ] UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN
# [ ] NEXT_PUBLIC_VAPID_PUBLIC_KEY + VAPID_PRIVATE_KEY (npx web-push generate-vapid-keys)
#
# VERCEL PROJECT:
# [ ] Add custom domain in Vercel > Settings > Domains
# [ ] Verify DNS is propagated (dig yourdomain.com)
# [ ] Verify HTTPS certificate is issued
#
# POST-DEPLOY VERIFICATION:
# [ ] Visit https://yourdomain.com — landing page loads
# [ ] Test: register with email, login, create draft
# [ ] Test: OAuth login with Google and Discord
# [ ] Test: /api/health returns {"status":"healthy"}
# [ ] Test: PWA install prompt appears on mobile
# [ ] Verify: Sentry receives a test error
# [ ] Verify: PostHog receives pageview events
