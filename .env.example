# Pokemon Draft - Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local or any file containing real API keys to version control!

# ============================================================================
# SUPABASE (REQUIRED)
# ============================================================================

# Your Supabase project URL
# Get this from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co

# Supabase anonymous/public API key (safe to expose in client-side code)
# This key has limited permissions defined by your RLS policies
# Get this from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# WARNING: Server-only key that bypasses RLS. NEVER expose client-side.
# Only used in API routes / server actions.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================================
# CLERK AUTHENTICATION (REQUIRED)
# ============================================================================

# Clerk publishable key (pk_test_* for dev, pk_live_* for prod)
# Get this from: https://dashboard.clerk.com > API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-key-here

# Clerk secret key (sk_test_* for dev, sk_live_* for prod)
# Get this from: https://dashboard.clerk.com > API Keys
CLERK_SECRET_KEY=sk_test_your-key-here

# Clerk route configuration
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# IMPORTANT: Production keys (pk_live_*, sk_live_*) must be set in Vercel
# Production environment scope, NOT preview scope. Preview deployments
# should use test keys to avoid polluting production user data.

# ============================================================================
# SITE URL (REQUIRED for production)
# ============================================================================

# Your deployed site URL (used for OG images, sitemap, robots.txt, callbacks)
# NEXT_PUBLIC_SITE_URL=https://draftpokemon.com

# ============================================================================
# SENTRY ERROR TRACKING (Phase 20)
# ============================================================================

# Sentry DSN for error tracking
# Get this from: https://sentry.io/settings/projects/your-project/keys/
# NEXT_PUBLIC_SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-project-id
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=pokemon-draft
# SENTRY_AUTH_TOKEN=sntrys_your-auth-token-here

# ============================================================================
# POSTHOG ANALYTICS (Phase 20)
# ============================================================================

# PostHog project API key
# Get this from: https://us.posthog.com/settings/project
# NEXT_PUBLIC_POSTHOG_KEY=phc_your-key-here
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ============================================================================
# RATE LIMITING -- Upstash Redis (RECOMMENDED for production)
# ============================================================================

# Upstash Redis REST credentials (free tier: 10K requests/day)
# Get this from: https://console.upstash.com
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token-here

# ============================================================================
# DISCORD WEBHOOK (for feedback page)
# ============================================================================

# Discord webhook URL for /feedback page submissions
# Create at: Discord Server Settings > Integrations > Webhooks
# NEXT_PUBLIC_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url

# ============================================================================
# PWA / PUSH NOTIFICATIONS (OPTIONAL)
# ============================================================================

# VAPID keys for Web Push notifications
# Generate with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
# VAPID_PRIVATE_KEY=your-vapid-private-key

# ============================================================================
# DEVELOPMENT FLAGS
# ============================================================================

# Node environment (development, production, test)
NODE_ENV=development

# Enable debug logging (true/false)
DEBUG=false

# Enable bundle analyzer (true/false)
# ANALYZE=true

# ============================================================================
# SECURITY NOTES
# ============================================================================
#
# 1. NEVER commit .env.local or .env.production to version control
# 2. Use different keys for development, staging, and production
# 3. Rotate API keys regularly (every 90 days recommended)
# 4. Use Supabase RLS policies to restrict what the anon key can access
# 5. Monitor API usage for unusual patterns
# 6. Use environment-specific Supabase projects (dev, staging, prod)
# 7. Clerk production keys must only be in Vercel Production scope

# ============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================================
#
# 1. VERCEL PROJECT SETUP:
#    [ ] Import repo to Vercel (vercel.com/new)
#    [ ] Add custom domain: draftpokemon.com (Settings > Domains)
#    [ ] Configure DNS (CNAME or A record per Vercel docs)
#    [ ] Wait for SSL certificate provisioning
#    [ ] Verify HTTPS works
#
# 2. VERCEL ENVIRONMENT VARIABLES (Production scope):
#    [ ] NEXT_PUBLIC_SUPABASE_URL
#    [ ] NEXT_PUBLIC_SUPABASE_ANON_KEY
#    [ ] NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY (pk_live_*)
#    [ ] CLERK_SECRET_KEY (sk_live_*)
#    [ ] NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
#    [ ] NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
#    [ ] NEXT_PUBLIC_SITE_URL=https://draftpokemon.com
#
# 3. CLERK DASHBOARD (Production instance):
#    [ ] Create production instance (or switch from dev)
#    [ ] Enable Discord OAuth provider -- set callback to https://draftpokemon.com
#    [ ] Enable Google OAuth provider -- set callback to https://draftpokemon.com
#    [ ] Enable Twitch OAuth provider -- set callback to https://draftpokemon.com
#    [ ] Add draftpokemon.com to allowed origins
#
# 4. DNS CONFIGURATION:
#    [ ] Add CNAME record pointing to cname.vercel-dns.com
#       (or A record to 76.76.21.21)
#    [ ] Wait for propagation (up to 48h, typically 15min-2h)
#    [ ] Verify with: dig draftpokemon.com
#
# 5. POST-DEPLOY VERIFICATION:
#    [ ] Visit https://draftpokemon.com -- landing page loads
#    [ ] Sign in with Discord -- no CSP errors in console
#    [ ] Sign in with Google -- no CSP errors in console
#    [ ] Create a draft -- Supabase connection works
#    [ ] /api/health returns healthy
#    [ ] Open browser DevTools Console -- no CSP violation warnings
